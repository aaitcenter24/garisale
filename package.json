{
  "name": "garisale-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --prefix apps/api run build",
    "lint": "prettier --check \"apps/api/src/**/*.ts\" \"scripts/**/*.js\"",
    "type-check": "tsc --noEmit -p apps/api/tsconfig.json",
    "check:imports": "node scripts/check-imports.js",
    "test:unit": "npm --prefix apps/api run test --",
    "test:integration": "npm --prefix apps/api run test:e2e --",
    "test:all": "npm --prefix apps/api run test && npm --prefix apps/api run test:e2e",
    "test:smoke": "node scripts/run-smoke-tests.js"
  },
  "overrides": {
    "lodash": "^4.17.21",
    "ws": "^8.18.0",
    "tar": "^7.5.16",
    "glob": "^10.5.0",
    "qs": "^6.11.2",
    "multer": "^1.4.5-lts.1",
    "picomatch": "^4.0.2",
    "tmp": "^0.2.3"
  }
}
