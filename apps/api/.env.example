# ==========================================
# Garisale — API Environment Configuration Example
# ==========================================

# 1. DATABASE & REDIS (Railway / Upstash)
# ------------------------------------------
# PostgreSQL URL (Automatically provided by Railway Database Service)
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/railway"

# Redis URL (If hosting on Upstash, prepend with "rediss://" for mandatory TLS)
# Format (Upstash): rediss://default:<password>@<host>:<port>
# Format (Railway Redis): redis://default:<password>@<host>:<port>
REDIS_URL="rediss://default:password@localhost:6379"

# 2. JWT KEYS (Asymmetric RS256 for Dealers, Symmetric HS256 for Admins)
# ----------------------------------------------------------------------
DEALER_JWT_ACCESS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
DEALER_JWT_ACCESS_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
DEALER_JWT_REFRESH_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
DEALER_JWT_REFRESH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Symmetric admin token signature key
ADMIN_JWT_SECRET="generate_at_least_64_hex_character_secret_key"

# 3. EXTERNAL SERVICES
# ---------------------
# WhatsApp Business API (Meta Developer portal)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_API_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# Greenweb BD (SMS Gateway)
GREENWEB_TOKEN=""
SMS_SENDER_ID=""

# Resend (Email Gateway)
RESEND_API_KEY=""
EMAIL_FROM="noreply@mail.garisale.com"

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# Sentry DSN
SENTRY_DSN=""

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
