  error_message String?   @map("error_message") @db.Text
  retry_count   Int       @default(0) @map("retry_count") @db.SmallInt
  metadata      Json?     @default("{}")
  created_at    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  dealership    Dealership @relation(fields: [dealership_id], references: [id])
  lead          Lead?      @relation(fields: [lead_id], references: [id])

  @@map("automation_log")
}

model PlatformCalendar {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  date         DateTime @db.Date
  name         String   @db.VarChar(100)
  type         String   @db.VarChar(50)
  country      String   @default("BD") @db.VarChar(10)

  @@unique([date, country])
  @@map("platform_calendar")
}

model Subscription {
  id                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id       String            @unique @db.Uuid
  plan_id             String            @db.Uuid
  tier                SubscriptionTier
  status              String            @default("active") @db.VarChar(20)
  started_at          DateTime          @default(now()) @map("started_at") @db.Timestamptz
  expires_at          DateTime          @map("expires_at") @db.Timestamptz
  cancelled_at        DateTime?         @map("cancelled_at") @db.Timestamptz
  cancellation_reason String?           @map("cancellation_reason") @db.Text
  auto_renew          Boolean           @default(true) @map("auto_renew")
  monthly_price_bdt   Decimal           @map("monthly_price_bdt") @db.Decimal(10, 2)
  currency            String            @default("BDT") @db.VarChar(3)
  created_at          DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updated_at          DateTime          @default(now()) @map("updated_at") @db.Timestamptz

  dealership          Dealership        @relation(fields: [dealership_id], references: [id])
  plan                PlanConfig        @relation(fields: [plan_id], references: [id])

  @@map("subscription")
}

model Invoice {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id    String          @db.Uuid
  invoice_no       String          @unique @db.VarChar(50)
  type             String          @default("subscription") @db.VarChar(30)
  amount_bdt       Decimal         @map("amount_bdt") @db.Decimal(10, 2)
  discount_bdt     Decimal         @default(0) @map("discount_bdt") @db.Decimal(10, 2)
  total_bdt        Decimal         @map("total_bdt") @db.Decimal(10, 2)
  status           String          @default("pending") @db.VarChar(20)
  due_date         DateTime        @map("due_date") @db.Date
  paid_at          DateTime?       @map("paid_at") @db.Timestamptz
  period_start     DateTime?       @map("period_start") @db.Date
  period_end       DateTime?       @map("period_end") @db.Date
  pdf_url          String?         @map("pdf_url") @db.Text
  idempotency_key  String?         @unique @map("idempotency_key") @db.VarChar(100)
  created_at       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updated_at       DateTime        @default(now()) @map("updated_at") @db.Timestamptz

  dealership       Dealership      @relation(fields: [dealership_id], references: [id])
  transactions     PaymentTransaction[]

  @@map("invoice")
}

model PaymentTransaction {
  id                     String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoice_id             String        @db.Uuid
  dealership_id          String        @db.Uuid
  idempotency_key        String        @unique @map("idempotency_key") @db.VarChar(100)
  payment_method         PaymentMethod @map("payment_method")
  gateway                String        @db.VarChar(30)
  amount_bdt             Decimal       @map("amount_bdt") @db.Decimal(10, 2)
  status                 String        @default("initiated") @db.VarChar(20)
  gateway_transaction_id String?       @map("gateway_transaction_id") @db.VarChar(255)
  gateway_response       Json?         @map("gateway_response")
  initiated_at           DateTime      @default(now()) @map("initiated_at") @db.Timestamptz
  completed_at           DateTime?     @map("completed_at") @db.Timestamptz
  failure_reason         String?       @map("failure_reason") @db.VarChar(255)
  attempt_number         Int           @default(1) @map("attempt_number") @db.SmallInt
  created_at             DateTime      @default(now()) @map("created_at") @db.Timestamptz

  invoice                Invoice       @relation(fields: [invoice_id], references: [id])
  dealership             Dealership    @relation(fields: [dealership_id], references: [id])

  @@map("payment_transaction")
}

model PlatformAuditLog {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actor_id     String   @db.Uuid
  actor_ip     String   @db.VarChar(45)
  action       String   @db.VarChar(100)
  before_state String?  @db.Text
  after_state  String?  @db.Text
  created_at   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("platform_audit_log")
}

model EntityChangeLog {
  id                     String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entity_type            String   @db.VarChar(100)
  entity_id              String   @db.Uuid
  action                 String   @db.VarChar(50)
  before_state           String?  @db.Text
  after_state            String?  @db.Text
  actor_role             String   @db.VarChar(50)
  impersonated_dealer_id String?  @db.Uuid
  actor_id               String   @db.Uuid
  created_at             DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("entity_change_log")
}


