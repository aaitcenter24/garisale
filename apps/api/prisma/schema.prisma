datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ENUMS
enum UserRole {
  admin_user
  dealer_owner
  manager
  salesperson
  technician
  buyer
  c2c_seller

  @@map("user_role")
}

enum UserStatus {
  active
  suspended
  pending_verification
  deleted

  @@map("user_status")
}

enum DealerStatus {
  pending_approval
  active
  suspended
  terminated

  @@map("dealer_status")
}

enum SubscriptionTier {
  free
  starter
  professional
  business
  enterprise

  @@map("subscription_tier")
}

enum VehicleCondition {
  new
  used
  reconditioned

  @@map("vehicle_condition")
}

enum VehicleStatus {
  acquired
  in_recon
  available
  reserved
  sold
  scrapped

  @@map("vehicle_status")
}

enum FuelType {
  petrol
  diesel
  hybrid
  electric
  cng
  lpg

  @@map("fuel_type")
}

enum TransmissionType {
  automatic
  manual
  cvt
  dct
  amt

  @@map("transmission_type")
}

enum ReconItemStatus {
  ok
  needs_work
  critical

  @@map("recon_item_status")
}

enum ReconTaskStatus {
  pending
  in_progress
  complete
  cancelled

  @@map("recon_task_status")
}

enum LeadStage {
  new
  contacted
  qualified
  test_drive
  quote_sent
  negotiation
  closed
  lost

  @@map("lead_stage")
}

enum LeadPriority {
  hot
  warm
  cold

  @@map("lead_priority")
}

enum LeadSource {
  walk_in
  marketplace
  dealer_website
  facebook_lead_ad
  whatsapp
  phone
  referral
  sms_campaign
  email_campaign
  social_media
  other

  @@map("lead_source")
}

enum DealType {
  cash
  finance
  lease
  exchange
  exchange_plus_cash

  @@map("deal_type")
}

enum DealStatus {
  draft
  pending_approval
  approved
  delivered
  cancelled

  @@map("deal_status")
}

enum PaymentMethod {
  bkash
  nagad
  rocket
  bank_transfer
  cash
  sslcommerz
  card
  cheque

  @@map("payment_method")
}

enum ListingType {
  dealer
  c2c

  @@map("listing_type")
}

enum ListingStatus {
  active
  reserved
  sold
  hidden
  archived
  expired
  under_review
  rejected

  @@map("listing_status")
}

enum DealRating {
  great_deal
  good_deal
  fair_price
  overpriced
  unrated

  @@map("deal_rating")
}

enum AutomationChannel {
  whatsapp
  facebook
  instagram
  email
  sms
  push

  @@map("automation_channel")
}

enum RecurCycle {
  weekly
  monthly
  quarterly
  annual

  @@map("recur_cycle")
}

enum LanguagePref {
  en
  bn

  @@map("language_pref")
}

enum SellerType {
  dealer
  private

  @@map("seller_type")
}

// MODELS

model User {
  id                   String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone                String        @unique @db.VarChar(20)
  email                String?       @unique @db.VarChar(255)
  password_hash        String?       @db.VarChar(255)
  full_name            String        @db.VarChar(255)
  role                 UserRole
  status               UserStatus    @default(pending_verification)
  preferred_language   LanguagePref  @default(bn) @map("preferred_language")
  avatar_url           String?       @map("avatar_url")
  fcm_token            String?       @map("fcm_token")
  fcm_token_updated_at DateTime?     @map("fcm_token_updated_at") @db.Timestamptz
  last_login_at        DateTime?     @map("last_login_at") @db.Timestamptz
  last_login_ip        String?       @map("last_login_ip") // stored as String/INET
  login_count          Int           @default(0) @map("login_count")
  failed_login_count   Int           @default(0) @map("failed_login_count")
  locked_until         DateTime?     @map("locked_until") @db.Timestamptz
  admin_role           String?       @map("admin_role") @db.VarChar(50)
  totp_secret          String?       @map("totp_secret") @db.VarChar(255)
  totp_enabled         Boolean       @default(false) @map("totp_enabled")
  totp_failed_attempts Int           @default(0) @map("totp_failed_attempts")
  created_at           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updated_at           DateTime      @default(now()) @map("updated_at") @db.Timestamptz
  deleted_at           DateTime?     @map("deleted_at") @db.Timestamptz

  dealershipsOwned     Dealership[]  @relation("DealershipOwner")
  dealershipsApproved  Dealership[]  @relation("DealerApprovedBy")
  dealershipsSuspended Dealership[]  @relation("DealerSuspendedBy")
  staffRecords         DealerStaff[] @relation("StaffUser")
  invitedStaff         DealerStaff[] @relation("StaffInvitedBy")
  deactivatedStaff     DealerStaff[] @relation("StaffDeactivatedBy")
  refreshTokens        RefreshToken[]
  defaultSettings      DealerSettings[] @relation("DefaultAssignedTo")
  vehicleStatusChanges VehicleStatusHistory[]
  reconAssessments     ReconAssessment[]
  reconTasksAssigned   ReconTask[]   @relation("ReconTaskAssignedTo")
  reconTasksCreated    ReconTask[]   @relation("ReconTaskCreatedBy")
  customers            Customer[]
  leadsAssigned        Lead[]        @relation("LeadAssignedTo")
  leadInteractions     LeadInteraction[]
  dealsSalesperson     Deal[]        @relation("DealSalesperson")
  dealsApproved        Deal[]        @relation("DealApprovedBy")
  dealPaymentsRecorded DealPayment[] @relation("DealPaymentRecordedBy")
  vehicleExpenses      VehicleExpense[]
  operationalExpenses  OperationalExpense[]
  marketplaceC2c       MarketplaceListing[] @relation("MarketplaceC2cSeller")

  @@map("user")
}

model Otp {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  phone        String      @db.VarChar(20)
  code         String      @db.VarChar(6)
  purpose      String      @db.VarChar(50)
  is_used      Boolean     @default(false) @map("is_used")
  attempts     Int         @default(0)
  expires_at   DateTime    @map("expires_at") @db.Timestamptz
  created_at   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  used_at      DateTime?   @map("used_at") @db.Timestamptz
  ip_address   String?     @map("ip_address")

  @@map("otp")
}

model RefreshToken {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String      @db.Uuid
  token_hash   String      @db.VarChar(255) @map("token_hash")
  device_info  String?     @map("device_info")
  ip_address   String?     @map("ip_address")
  expires_at   DateTime    @map("expires_at") @db.Timestamptz
  revoked_at   DateTime?   @map("revoked_at") @db.Timestamptz
  last_used_at DateTime?   @map("last_used_at") @db.Timestamptz
  created_at   DateTime    @default(now()) @map("created_at") @db.Timestamptz

  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

model Dealership {
  id                      String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  owner_id                String            @db.Uuid
  business_name           String            @map("business_name") @db.VarChar(255)
  slug                    String            @unique @db.VarChar(255)
  trade_license_no        String?           @map("trade_license_no") @db.VarChar(100)
  nid_no                  String?           @map("nid_no") @db.VarChar(30)
  status                  DealerStatus      @default(pending_approval)
  subscription_tier       SubscriptionTier  @default(free) @map("subscription_tier")
  subscription_expires_at DateTime?         @map("subscription_expires_at") @db.Timestamptz
  listing_limit           Int               @default(10) @map("listing_limit")
  staff_seat_limit        Int               @default(1) @map("staff_seat_limit")
  location_limit          Int               @default(1) @map("location_limit")
  district                String            @db.VarChar(100)
  division                String            @db.VarChar(100)
  address                 String?
  lat                     Decimal?          @db.Decimal(9, 6)
  lng                     Decimal?          @db.Decimal(9, 6)
  logo_url                String?           @map("logo_url")
  cover_photo_url         String?           @map("cover_photo_url")
  primary_color           String?           @map("primary_color") @db.VarChar(7)
  secondary_color         String?           @map("secondary_color") @db.VarChar(7)
  phone                   String            @db.VarChar(20)
  whatsapp_number         String?           @map("whatsapp_number") @db.VarChar(20)
  email                   String?           @db.VarChar(255)
  website_url             String?           @map("website_url")
  business_hours          Json?             @map("business_hours")
  rating                  Decimal?          @db.Decimal(3, 2)
  review_count            Int               @default(0) @map("review_count")
  total_listings          Int               @default(0) @map("total_listings")
  total_deals             Int               @default(0) @map("total_deals")
  approved_by             String?           @map("approved_by") @db.Uuid
  approved_at             DateTime?         @map("approved_at") @db.Timestamptz
  suspended_by            String?           @map("suspended_by") @db.Uuid
  suspended_at            DateTime?         @map("suspended_at") @db.Timestamptz
  suspension_reason       String?           @map("suspension_reason")
  terminated_at           DateTime?         @map("terminated_at") @db.Timestamptz
  termination_reason      String?           @map("termination_reason")
  discount_threshold_pct  Decimal           @default(10.00) @map("discount_threshold_pct") @db.Decimal(5, 2)
  target_margin_pct       Decimal           @default(20.00) @map("target_margin_pct") @db.Decimal(5, 2)
  auto_publish_marketplace Boolean          @default(true) @map("auto_publish_marketplace")
  auto_post_social        Boolean           @default(false) @map("auto_post_social")
  posts_per_week          Int               @default(3) @map("posts_per_week")
  created_at              DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updated_at              DateTime          @default(now()) @map("updated_at") @db.Timestamptz
  deleted_at              DateTime?         @map("deleted_at") @db.Timestamptz

  owner                   User              @relation("DealershipOwner", fields: [owner_id], references: [id])
  approvedBy              User?             @relation("DealerApprovedBy", fields: [approved_by], references: [id])
  suspendedBy             User?             @relation("DealerSuspendedBy", fields: [suspended_by], references: [id])

  locations               DealershipLocation[]
  staff                   DealerStaff[]
  settings                DealerSettings?
  vehicles                Vehicle[]
  statusHistory           VehicleStatusHistory[]
  reconAssessments        ReconAssessment[]
  reconTasks              ReconTask[]
  customers               Customer[]
  leads                   Lead[]
  leadInteractions        LeadInteraction[]
  deals                   Deal[]
  dealPayments            DealPayment[]
  vehicleExpenses         VehicleExpense[]
  operationalExpenses     OperationalExpense[]
  marketplaceListings     MarketplaceListing[]
  maestroInsights         MaestroInsight[]
  automationRules         AutomationRule[]
  automationLogs          AutomationLog[]
  subscription            Subscription?
  invoices                Invoice[]
  paymentTransactions     PaymentTransaction[]

  @@map("dealership")
}

model DealershipLocation {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id  String      @db.Uuid
  name           String      @db.VarChar(255)
  address        String
  district       String      @db.VarChar(100)
  division       String      @db.VarChar(100)
  lat            Decimal?    @db.Decimal(9, 6)
  lng            Decimal?    @db.Decimal(9, 6)
  phone          String?     @db.VarChar(20)
  is_primary     Boolean     @default(false) @map("is_primary")
  is_active      Boolean     @default(true) @map("is_active")
  created_at     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updated_at     DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  dealership     Dealership  @relation(fields: [dealership_id], references: [id], onDelete: Cascade)
  staff          DealerStaff[]
  vehicles       Vehicle[]
  leads          Lead[]
  deals          Deal[]

  @@map("dealership_location")
}

model DealerStaff {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id  String      @db.Uuid
  user_id        String      @db.Uuid
  role           UserRole
  location_id    String?     @db.Uuid
  is_active      Boolean     @default(true) @map("is_active")
  invited_by     String?     @db.Uuid
  invited_at     DateTime    @default(now()) @map("invited_at") @db.Timestamptz
  accepted_at    DateTime?   @map("accepted_at") @db.Timestamptz
  deactivated_at DateTime?   @map("deactivated_at") @db.Timestamptz
  deactivated_by String?     @db.Uuid

  sees_all_leads  Boolean    @default(false) @map("sees_all_leads")
  commission_rate Decimal?   @map("commission_rate") @db.Decimal(5, 2)

  created_at     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updated_at     DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  dealership     Dealership  @relation(fields: [dealership_id], references: [id], onDelete: Cascade)
  user           User        @relation("StaffUser", fields: [user_id], references: [id], onDelete: Cascade)
  location       DealershipLocation? @relation(fields: [location_id], references: [id])
  invitedBy      User?       @relation("StaffInvitedBy", fields: [invited_by], references: [id])
  deactivatedBy  User?       @relation("StaffDeactivatedBy", fields: [deactivated_by], references: [id])

  @@unique([dealership_id, user_id])
  @@map("dealer_staff")
}

model PlanConfig {
  id                    String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tier                  SubscriptionTier  @unique
  display_name          String            @map("display_name") @db.VarChar(50)
  monthly_price_bdt     Decimal           @map("monthly_price_bdt") @db.Decimal(10, 2)
  listing_limit         Int               @map("listing_limit")
  staff_seat_limit      Int               @map("staff_seat_limit")
  location_limit        Int               @map("location_limit")
  sms_quota_monthly     Int               @map("sms_quota_monthly")
  features              Json
  is_active             Boolean           @default(true) @map("is_active")
  created_at            DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updated_at            DateTime          @default(now()) @map("updated_at") @db.Timestamptz
  subscriptions         Subscription[]

  @@map("plan_config")
}

model DealerSettings {
  id                        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id             String      @unique @db.Uuid
  notify_new_lead_sms       Boolean     @default(true) @map("notify_new_lead_sms")
  notify_new_lead_push      Boolean     @default(true) @map("notify_new_lead_push")
  notify_aging_sms          Boolean     @default(true) @map("notify_aging_sms")
  notify_hot_lead_sms       Boolean     @default(true) @map("notify_hot_lead_sms")
  notify_daily_summary_sms  Boolean     @default(true) @map("notify_daily_summary_sms")
  notify_daily_summary_push Boolean     @default(true) @map("notify_daily_summary_push")
  daily_summary_time        String      @default("08:00:00") @map("daily_summary_time") // DB: TIME
  lead_assignment_mode      String      @default("round_robin") @map("lead_assignment_mode")
  default_assigned_to       String?     @db.Uuid @map("default_assigned_to")
  whatsapp_away_enabled     Boolean     @default(false) @map("whatsapp_away_enabled")
  whatsapp_greeting_enabled Boolean     @default(false) @map("whatsapp_greeting_enabled")
  facebook_away_enabled     Boolean     @default(false) @map("facebook_away_enabled")
  post_approval_required    Boolean     @default(true) @map("post_approval_required")
  optimal_post_time         String      @default("09:00:00") @map("optimal_post_time")
  default_loan_rate_pct     Decimal     @default(9.00) @map("default_loan_rate_pct") @db.Decimal(5, 2)
  created_at                DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updated_at                DateTime    @default(now()) @map("updated_at") @db.Timestamptz

  dealership                Dealership  @relation(fields: [dealership_id], references: [id], onDelete: Cascade)
  assignedUser              User?       @relation("DefaultAssignedTo", fields: [default_assigned_to], references: [id])

  @@map("dealer_settings")
}

model Vehicle {
  id                    String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id         String            @db.Uuid
  location_id           String?           @db.Uuid
  stock_no              String            @map("stock_no") @db.VarChar(20)
  vin                   String?           @db.VarChar(17)
  registration_no       String?           @map("registration_no") @db.VarChar(30)
  make                  String            @db.VarChar(100)
  model                 String            @db.VarChar(100)
  year                  Int               @db.SmallInt
  variant               String?           @db.VarChar(200)
  body_type             String?           @map("body_type") @db.VarChar(50)
  engine_cc             Int?              @map("engine_cc")
  engine_type           String?           @map("engine_type") @db.VarChar(50)
  fuel_type             FuelType          @default(petrol) @map("fuel_type")
  transmission          TransmissionType  @default(automatic)
  drive_type            String?           @map("drive_type") @db.VarChar(10)
  seating_capacity      Int?              @map("seating_capacity") @db.SmallInt
  color                 String?           @db.VarChar(50)
  doors                 Int?              @db.SmallInt
  condition             VehicleCondition  @default(used)
  mileage_km            Int               @map("mileage_km")
  mileage_bucket        String            @map("mileage_bucket") @db.VarChar(20)
  asking_price          Decimal           @map("asking_price") @db.Decimal(12, 2)
  acquisition_cost      Decimal?          @map("acquisition_cost") @db.Decimal(12, 2)
  recon_total           Decimal           @default(0) @map("recon_total") @db.Decimal(12, 2)
  net_profit_estimate   Decimal?          @map("net_profit_estimate") @db.Decimal(12, 2)
  floor_plan_cost       Decimal?          @map("floor_plan_cost") @db.Decimal(12, 2)
  acquisition_source    String?           @map("acquisition_source") @db.VarChar(50)
  acquisition_date      DateTime?         @map("acquisition_date") @db.Date
  acquired_from         String?           @map("acquired_from") @db.VarChar(255)
  status                VehicleStatus     @default(acquired)
  available_at          DateTime?         @map("available_at") @db.Timestamptz
  sold_at               DateTime?         @map("sold_at") @db.Timestamptz
  photos                Json              @default("[]")
  video_url             String?           @map("video_url")
  photo_count           Int               @default(0) @map("photo_count")
  marketplace_published Boolean           @default(true) @map("marketplace_published")
  last_synced_at        DateTime?         @map("last_synced_at") @db.Timestamptz
  sync_error            String?           @map("sync_error")
  specs                 Json              @default("{}")
  internal_notes        String?           @map("internal_notes")
  description           String?
  features              Json              @default("[]")
  created_at            DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updated_at            DateTime          @default(now()) @map("updated_at") @db.Timestamptz
  deleted_at            DateTime?         @map("deleted_at") @db.Timestamptz

  dealership            Dealership        @relation(fields: [dealership_id], references: [id])
  location              DealershipLocation? @relation(fields: [location_id], references: [id])

  statusHistory         VehicleStatusHistory[]
  reconAssessment       ReconAssessment?
  reconTasks            ReconTask[]
  leads                 Lead[]
  deals                 Deal[]            @relation("DealVehicle")
  dealsTradeIn          Deal[]            @relation("DealTradeInVehicle")
  expenses              VehicleExpense[]
  marketplaceListings   MarketplaceListing[]

  @@unique([dealership_id, stock_no])
  @@map("vehicle")
}

model VehicleStatusHistory {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id String        @db.Uuid
  vehicle_id    String        @db.Uuid
  from_status   VehicleStatus? @map("from_status")
  to_status     VehicleStatus @map("to_status")
  changed_by    String        @db.Uuid @map("changed_by")
  reason        String?
  created_at    DateTime      @default(now()) @map("created_at") @db.Timestamptz

  dealership    Dealership    @relation(fields: [dealership_id], references: [id])
  vehicle       Vehicle       @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [changed_by], references: [id])

  @@map("vehicle_status_history")
}

model ReconAssessment {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id     String          @db.Uuid
  vehicle_id        String          @unique @db.Uuid
  engine_status     ReconItemStatus @default(ok) @map("engine_status")
  body_status       ReconItemStatus @default(ok) @map("body_status")
  paint_status      ReconItemStatus @default(ok) @map("paint_status")
  interior_status   ReconItemStatus @default(ok) @map("interior_status")
  electricals_status ReconItemStatus @default(ok) @map("electricals_status")
  tyres_status      ReconItemStatus @default(ok) @map("tyres_status")
  ac_status         ReconItemStatus @default(ok) @map("ac_status")
  brakes_status     ReconItemStatus @default(ok) @map("brakes_status")
  engine_notes      String?         @map("engine_notes")
  body_notes        String?         @map("body_notes")
  paint_notes       String?         @map("paint_notes")
  interior_notes    String?         @map("interior_notes")
  electricals_notes String?         @map("electricals_notes")
  tyres_notes       String?         @map("tyres_notes")
  ac_notes          String?         @map("ac_notes")
  brakes_notes      String?         @map("brakes_notes")
  overall_notes     String?         @map("overall_notes")
  assessed_by       String          @db.Uuid @map("assessed_by")
  assessed_at       DateTime        @default(now()) @map("assessed_at") @db.Timestamptz
  completed_at      DateTime?       @map("completed_at") @db.Timestamptz
  created_at        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updated_at        DateTime        @default(now()) @map("updated_at") @db.Timestamptz

  dealership        Dealership      @relation(fields: [dealership_id], references: [id])
  vehicle           Vehicle         @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  assessor          User            @relation(fields: [assessed_by], references: [id])
  tasks             ReconTask[]

  @@map("recon_assessment")
}

model ReconTask {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dealership_id    String          @db.Uuid
  vehicle_id       String          @db.Uuid
  assessment_id    String          @db.Uuid
  category         String          @db.VarChar(50)
  description      String
  assigned_to_user String?         @db.Uuid @map("assigned_to_user")
  assigned_to_name String?         @map("assigned_to_name") @db.VarChar(255)
  estimated_cost   Decimal?        @map("estimated_cost") @db.Decimal(12, 2)
  actual_cost      Decimal?        @map("actual_cost") @db.Decimal(12, 2)
  status           ReconTaskStatus @default(pending)
  priority         Int             @default(2) @db.SmallInt
  started_at       DateTime?       @map("started_at") @db.Timestamptz
  completed_at     DateTime?       @map("completed_at") @db.Timestamptz
  notes            String?
  receipt_url      String?         @map("receipt_url")
  created_by       String          @db.Uuid @map("created_by")
  created_at       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updated_at       DateTime        @default(now()) @map("updated_at") @db.Timestamptz

  dealership       Dealership      @relation(fields: [dealership_id], references: [id])
  vehicle          Vehicle         @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
